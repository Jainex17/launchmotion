    { "type": "KineticText", "duration": 3.0,
      "props": { "lines": ["An inbox that", "**clears itself**"], "size": 112, "exitUp": true } },

    { "type": "KineticText", "duration": 2.6,
      "props": { "lines": ["across threads,", "calendars & contacts"], "size": 90, "exitUp": true } },

    { "type": "SearchType", "duration": 4.2,
      "props": { "background": "#ffffff", "mark": "☁",
        "query": "decline all meetings next week and propose async", "mode": "Ask AI", "model": "GPT-5.5" } },

    { "type": "ChatThread", "duration": 5.2,
      "props": { "light": false, "items": [
        { "kind": "step", "text": "Reading next week's calendar — 6 meetings found", "icon": "›" },
        { "kind": "step", "text": "Drafting a polite async proposal for each", "icon": "›" },
        { "kind": "sub", "text": "Spawned sub-agent · Rescheduling Design sync", "icon": "▣" },
        { "kind": "sub", "text": "Spawned sub-agent · Declining Vendor call", "icon": "▣" },
        { "kind": "ok", "text": "6 replies sent · 4 hours freed this week" }
      ], "itemDelay": 18 } },

    { "type": "ChatThread", "duration": 3.0,
      "props": { "items": [
        { "kind": "me", "text": "wait, how did you just do that?" },
        { "kind": "step", "text": "I'm a frontier inbox agent built for your long, messy threads.", "icon": "✦" }
      ], "itemDelay": 20 } },

    { "type": "BenchmarkBars", "duration": 4.2,
      "props": { "title": "Inbox Agent Benchmark", "sub": "RealMail-500 — including impossible tasks",
        "rows": [
          { "label": "Nimbus", "dim": "GPT 5.5", "value": 98, "win": true },
          { "label": "Superhuman AI", "value": 91 },
          { "label": "Copilot", "dim": "Outlook", "value": 84 },
          { "label": "Gmail Smart", "value": 73 }

        { "kind": "step", "text": "Please sign in to continue", "icon": "✕" },
        { "kind": "step", "text": "I can't access your calendar", "icon": "✕" }
      ], "itemDelay": 16 } },

    { "type": "KineticText", "duration": 1.8,
      "props": { "lines": ["Introducing"], "size": 92, "exitUp": true } },

    { "type": "BrandReveal", "duration": 3.0,
